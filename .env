# ----------------------------------------------------------------------
# Authentication and Credentials
# ----------------------------------------------------------------------
SECRET_TOKEN=changeme

# Hugging Face Tokens:
HF_TOKEN=changeme
HUGGING_FACE_HUB_TOKEN=changeme
HF_HOME="/workspace/huggingface-cache"

# ----------------------------------------------------------------------
# Model Configuration (vLLM OpenAI Server)
# ----------------------------------------------------------------------
MODEL_NAME="zai-org/GLM-4.6-FP8"
TENSOR_PARALLEL_SIZE=4
TRUST_REMOTE_CODE=true

# ----------------------------------------------------------------------
# Precision and Quantization (vLLM)
# ----------------------------------------------------------------------
TORCH_DTYPE=auto
# QUANTIZATION can be empty or set if needed, e.g. "awq" or "gptq"
# QUANTIZATION=

# ----------------------------------------------------------------------
# Optimization and Memory Management
# ----------------------------------------------------------------------
MAX_MODEL_LEN=1024
GPU_MEMORY_UTILIZATION=0.90

# ----------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------
DEFAULT_SYSTEM_PROMPT_EN=
DEFAULT_SYSTEM_PROMPT_ES=

# Prebuild constrained vocab regex patterns at startup
PREBUILD_PREFIX=true
PREBUILD_WORD_COUNTS=3000

# ----------------------------------------------------------------------
# Embedded vLLM OpenAI Server config (spawned by FastAPI)
# ----------------------------------------------------------------------
VLLM_HOST=127.0.0.1
VLLM_PORT=8011
LAUNCH_VLLM_SERVER=true
VLLM_LOG_LEVEL=info

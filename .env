# Auth, batch etc. (same as before)
HF_TOKEN=changeme
SECRET_TOKEN=changeme
BATCH_JOB_PIPELINE_SIZE=8

# Hugging Face cache (persist this path)
HF_HOME=/workspace/huggingface-cache
HUGGINGFACE_HUB_CACHE=/workspace/huggingface-cache

# Backend
MODEL_NAME=Qwen/Qwen3-235B-A22B-Instruct-2507-FP8
BACKEND=trtllm
TRUST_REMOTE_CODE=true

# Beam / TRT-LLM specifics
TLLM_MAX_BEAM_WIDTH=10
TLLM_DISABLE_OVERLAP_SCHEDULER=true
TLLM_DISABLE_CUDA_GRAPHS=true

# Constrained vocab prebuild (same as before)
PREBUILD_PREFIX=true
PREBUILD_WORD_COUNTS=3000
PREBUILD_LANGS=es

# Auth, batch etc. (same as before)
SECRET_TOKEN=changeme
BATCH_JOB_PIPELINE_SIZE=8

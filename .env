# ----------------------------------------------------------------------
# Authentication and Credentials
# ----------------------------------------------------------------------
SECRET_TOKEN=changeme

# Hugging Face Tokens:
HF_TOKEN=changeme
HUGGING_FACE_HUB_TOKEN=changeme
HF_HOME="/workspace/huggingface-cache"

# ----------------------------------------------------------------------
# Model Configuration (vLLM Server)
# ----------------------------------------------------------------------
MODEL_NAME="zai-org/GLM-4.6-FP8"
TENSOR_PARALLEL_SIZE=4
TRUST_REMOTE_CODE=true
TORCH_DTYPE=auto
MAX_MODEL_LEN=1024
GPU_MEMORY_UTILIZATION=0.90

# ----------------------------------------------------------------------
# vLLM OpenAI Server runtime
# ----------------------------------------------------------------------
# This proxy will auto-start a vLLM OpenAI server on startup if true.
START_VLLM_SERVER=true
VLLM_HOST=127.0.0.1
VLLM_PORT=8011
GUIDED_DECODING_BACKEND=lm-format-enforcer

# ----------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------
DEFAULT_SYSTEM_PROMPT_EN=
DEFAULT_SYSTEM_PROMPT_ES=
PREBUILD_PREFIX=true
# Prebuild examples for Spanish (you can set multiple: "500,1000,5000")
PREBUILD_WORD_COUNTS=3000

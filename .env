# Hugging Face
HF_TOKEN=
HF_HOME=/workspace/huggingface-cache
HUGGINGFACE_HUB_CACHE=/workspace/huggingface-cache

# TRT-LLM caps (small to allow beam width 10 without OOM)
MAX_BEAM_WIDTH=5
MAX_BATCH_SIZE=1
MAX_INPUT_LEN=512
MAX_SEQ_LEN=1024
MAX_NUM_TOKENS=1024

# KV cache override:
# - Use "auto" (default) to let TRT-LLM pick (fp16/bf16).
# - Set to "fp8" ONLY on Hopper (H100) if you want fp8 KV-cache.
KV_CACHE_DTYPE=auto

# API auth
SECRET_TOKEN=changeme

# Model
MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507

# Constrained vocab prebuild
PREBUILD_PREFIX=true
PREBUILD_LANGS=es
PREBUILD_WORD_COUNTS=3000

# Optional: compiled kernel caches (persist on your /workspace volume)
XDG_CACHE_HOME=/workspace/.cache
TRITON_CACHE_DIR=/workspace/.cache/triton
TORCHINDUCTOR_CACHE_DIR=/workspace/.cache/torchinductor

# Batch job
BATCH_JOB_TEMP_DIR=/workspace/batches

# Optional TP/EP/DP config for larger or MoE models
PARALLEL_CONFIG_PATH=/workspace/app/parallel_config.yaml

# Logging
LOG_LEVEL=INFO

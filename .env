# ----------------------------------------------------------------------
# Authentication and Credentials
# ----------------------------------------------------------------------
# Authentication token required to access the API endpoints
SECRET_TOKEN=changeme

# Hugging Face Tokens:
# vLLM and transformers will pick either; keep both if you like.
HF_TOKEN=changeme
HUGGING_FACE_HUB_TOKEN=changeme

HF_HOME="/workspace/huggingface-cache"

# ----------------------------------------------------------------------
# Model Configuration (vLLM Engine)
# ----------------------------------------------------------------------
# Target model
MODEL_NAME="zai-org/GLM-4.6-FP8"

# Tensor Parallelism. Set to your actual GPU count.
TENSOR_PARALLEL_SIZE=4

# Trust Remote Code: Required for custom architectures like Kimi-K2.
TRUST_REMOTE_CODE=true

# ----------------------------------------------------------------------
# Precision and Quantization (vLLM Engine)
# ----------------------------------------------------------------------
# Unset the QUANTIZATION variable (or set it to an empty string)
QUANTIZATION=

# Set DTYPE to "auto" to let vLLM load the model's native FP8 weights
TORCH_DTYPE="auto"

# ----------------------------------------------------------------------
# Optimization and Memory Management
# ----------------------------------------------------------------------
# Max context length. Keep small if you want to minimize KV cache.
MAX_MODEL_LEN=1024

# GPU Memory utilization fraction (default 0.90).
GPU_MEMORY_UTILIZATION=0.90

# ----------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------
# Default system prompts (leave empty for none)
DEFAULT_SYSTEM_PROMPT_EN=
DEFAULT_SYSTEM_PROMPT_ES=

# Prebuild constrained vocab regex parsers at startup
PREBUILD_PREFIX=true
# Comma-separated list of word counts to prebuild (Spanish only per your note)
PREBUILD_WORD_COUNTS=3000

# ----------------------------------------------------------------------
# Authentication and Credentials
# ----------------------------------------------------------------------

# Authentication token required to access the API endpoints
SECRET_TOKEN=changeme

# Hugging Face Token (Required for authentication and accessing potentially gated models)
HF_TOKEN=changeme

HF_HOME="/workspace/huggingface-cache"

# ----------------------------------------------------------------------
# Model Configuration (vLLM Engine)
# ----------------------------------------------------------------------
# WARNING: This configuration requires 16x A100/H100 GPUs (1.2TB VRAM)
# ----------------------------------------------------------------------

# Set the target model
MODEL_NAME="moonshotai/Kimi-K2-Instruct-0905"

# Tensor Parallelism: CRITICAL for multi-GPU inference.
# Must match the total number of GPUs available in the cluster (16 for FP8).
TENSOR_PARALLEL_SIZE=8

# Trust Remote Code: Required to load the custom architecture of Kimi-K2.
TRUST_REMOTE_CODE="true"

# ----------------------------------------------------------------------
# Precision and Quantization (vLLM Engine)
# ----------------------------------------------------------------------

# Quantization Method: Explicitly tell vLLM to load the pre-quantized FP8 weights.
# Options: fp8 | awq | gptq | bitsandbytes | None
QUANTIZATION="fp8"

# Dtype: 'bfloat16' is strongly recommended for stability and performance on A100/H100 GPUs.
# This affects the compute precision for operations not covered by FP8.
TORCH_DTYPE=bfloat16

# ----------------------------------------------------------------------
# Optimization and Memory Management
# ----------------------------------------------------------------------

# Max Context Length: Kimi-K2 defaults to 256K context, which consumes massive VRAM for the KV Cache.
# We strictly limit it here (e.g., to 32K) to prevent Out-of-Memory (OOM) errors.
MAX_MODEL_LEN=1024

# GPU Memory Utilization: The fraction of GPU memory vLLM is allowed to use (default 0.90).
# If you encounter OOM errors during inference, try reducing this (e.g., to 0.88).
GPU_MEMORY_UTILIZATION=0.93

# ----------------------------------------------------------------------
# Application Settings (Retained from original)
# ----------------------------------------------------------------------

# Default system prompts (leave empty for no system prompt)
DEFAULT_SYSTEM_PROMPT_EN=
DEFAULT_SYSTEM_PROMPT_ES=

# Prebuild constrained vocab prefix functions (RegexParsers) at startup
PREBUILD_PREFIX=true
# Comma-separated list of word counts to prebuild
PREBUILD_WORD_COUNTS=3000
